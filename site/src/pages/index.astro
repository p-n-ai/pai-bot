---
import BaseLayout from "@/layouts/BaseLayout.astro";

const features = [
  {
    title: "Proactive Learning",
    desc: "Doesn't wait for students to ask. Initiates study sessions, sends review nudges, and respects quiet hours.",
    icon: "M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9",
  },
  {
    title: "Spaced Repetition",
    desc: "SM-2 algorithm schedules reviews at optimal intervals. Tracks mastery per topic with adaptive difficulty.",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
  },
  {
    title: "Battles & Streaks",
    desc: "Challenge classmates to 5-question battles. Earn XP, maintain streaks, and climb the leaderboard.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    title: "Multi-Channel",
    desc: "Works on Telegram, WhatsApp, and embeddable web chat. Same bot, same progress, any platform.",
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
  },
  {
    title: "Curriculum-Aware",
    desc: "Follows real syllabi (KSSM, more coming). Every explanation cites the curriculum source. Not generic chat.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  },
  {
    title: "Open Source",
    desc: "Apache 2.0. Self-host on your own server. Full data ownership. Community-contributed curricula.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  },
];

const providers = [
  "OpenAI", "Anthropic", "Google Gemini", "DeepSeek", "OpenRouter", "Ollama",
];

const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/$/, "")}${path}`;
---

<BaseLayout title="P&AI Bot — Open-Source AI Learning Agent">
  <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[32rem] bg-[linear-gradient(180deg,color-mix(in_oklch,var(--primary)_12%,transparent)_0%,transparent_72%)]"></div>
  <div class="pointer-events-none absolute left-[8%] top-20 -z-10 size-72 rounded-full bg-primary/8 blur-3xl"></div>
  <div class="pointer-events-none absolute right-[10%] top-40 -z-10 size-80 rounded-full bg-secondary blur-3xl opacity-45"></div>

  <!-- Hero -->
  <section class="mx-auto max-w-4xl py-20 text-center lg:py-28">
    <h1 class="text-5xl font-semibold tracking-[-0.06em] leading-[0.95] text-balance sm:text-6xl lg:text-7xl">
      AI tutor that<br />
      <span class="text-primary">starts the conversation.</span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-muted-foreground">
      P&AI Bot teaches students through chat — Telegram, WhatsApp, or your website.
      It doesn't wait for questions. It initiates study sessions, tracks mastery with spaced repetition,
      and keeps students motivated through battles, streaks, and leaderboards.
    </p>

    <p class="mx-auto mt-3 max-w-lg text-base text-muted-foreground/80">
      Content is commodity. <strong class="text-foreground">Motivation is the moat.</strong>
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://t.me/pai_learning_bot"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex h-12 items-center gap-2 rounded-full bg-primary px-7 text-sm font-semibold text-primary-foreground shadow-[0_12px_30px_color-mix(in_oklch,var(--primary)_18%,transparent)] transition hover:bg-primary/90 active:translate-y-px"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        Try on Telegram
      </a>
      <a
        href={withBase("/getting-started/setup/")}
        class="inline-flex h-12 items-center gap-2 rounded-full border border-border/80 bg-card/80 px-7 text-sm font-semibold text-foreground shadow-[0_10px_24px_color-mix(in_oklch,var(--foreground)_5%,transparent)] backdrop-blur transition hover:bg-muted active:translate-y-px"
      >
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20M4 19.5A2.5 2.5 0 004 17V5a2 2 0 012-2h14v14H6.5A2.5 2.5 0 004 19.5z"/></svg>
        Self-Host Guide
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="mx-auto max-w-5xl py-16">
    <h2 class="text-center text-2xl font-semibold tracking-tight">
      What makes it different
    </h2>
    <p class="mx-auto mt-3 max-w-lg text-center text-muted-foreground">
      Not another chatbot wrapper. A complete learning agent with pedagogy, progress tracking, and motivation built in.
    </p>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map(({ title, desc, icon }) => (
        <div class="rounded-[22px] border border-border/80 bg-card/80 p-6 shadow-[0_10px_26px_color-mix(in_oklch,var(--foreground)_4%,transparent)] backdrop-blur transition hover:shadow-[0_14px_36px_color-mix(in_oklch,var(--foreground)_6%,transparent)]">
          <div class="mb-4 flex size-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold">{title}</h3>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Providers -->
  <section class="mx-auto max-w-3xl py-16 text-center">
    <h2 class="text-2xl font-semibold tracking-tight">
      Works with any AI provider
    </h2>
    <p class="mx-auto mt-3 max-w-lg text-muted-foreground">
      Route tasks to the best model. Teaching uses your best model, grading uses the cheapest. Automatic fallback chain. Self-host with Ollama for zero API cost.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      {providers.map((name) => (
        <span class="rounded-full border border-border/80 bg-card/80 px-4 py-2 text-sm font-medium text-foreground backdrop-blur">
          {name}
        </span>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-3xl py-16 text-center">
    <div class="rounded-[28px] border border-border/80 bg-card/80 p-10 shadow-[0_16px_44px_color-mix(in_oklch,var(--foreground)_6%,transparent)] backdrop-blur">
      <h2 class="text-2xl font-semibold tracking-tight">Ready to try it?</h2>
      <p class="mx-auto mt-3 max-w-md text-muted-foreground">
        Chat with the bot on Telegram in 10 seconds, or self-host for your school in under 10 minutes.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://t.me/pai_learning_bot"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-11 items-center gap-2 rounded-full bg-primary px-6 text-sm font-semibold text-primary-foreground shadow-[0_10px_24px_color-mix(in_oklch,var(--primary)_16%,transparent)] transition hover:bg-primary/90 active:translate-y-px"
        >
          Try on Telegram
        </a>
        <a
          href="https://github.com/p-n-ai/pai-bot"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-11 items-center gap-2 rounded-full border border-border/80 px-6 text-sm font-semibold text-foreground transition hover:bg-muted active:translate-y-px"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
