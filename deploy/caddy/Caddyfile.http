{
	auto_https off
}

:80 {
	handle /api/* {
		reverse_proxy app:8080
	}

	handle /healthz {
		reverse_proxy app:8080
	}

	handle /ws/* {
		reverse_proxy app:8080
	}

	handle /embed/* {
		reverse_proxy app:8080
	}

	handle /webhook/* {
		reverse_proxy app:8080
	}

	handle {
		reverse_proxy admin:3000
	}
}
