{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "react-perf",
    "jsx-a11y",
    "import"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "rules": {
    "react-in-jsx-scope": "off",
    "react/react-in-jsx-scope": "off",
    "no-unassigned-import": "off",
    "import/no-unassigned-import": "off"
  },
  "env": {
    "builtin": true
  }
}
