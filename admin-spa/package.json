{
  "name": "admin-spa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run lint:ox && pnpm run format:check && pnpm run fallow && pnpm run test && pnpm run build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ox": "oxlint --tsconfig tsconfig.json --react-plugin --jsx-a11y-plugin --import-plugin --deny correctness --deny suspicious --deny perf --deny unicorn --deny react-perf --allow react-in-jsx-scope --allow no-unassigned-import src vite.config.ts",
    "lint:ox:fix": "pnpm run lint:ox -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "fallow": "fallow --fail-on-issues --score --dupes-mode strict",
    "fallow:audit": "fallow audit --fail-on-issues",
    "test": "vitest run",
    "preview": "vite preview",
    "intent:list": "intent list",
    "intent:router": "intent load @tanstack/router-core#router-core",
    "intent:vite": "intent load @tanstack/router-plugin#router-plugin"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/router-core": "^1.169.2",
    "agentation": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/intent": "^0.0.41",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fallow": "^2.67.0",
    "jsdom": "^29.1.1",
    "neostandard": "^0.13.0",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
